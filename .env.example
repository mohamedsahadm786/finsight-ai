# ============================================
# FinSight AI — Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# NEVER commit the .env file to Git!

# ---------- Application ----------
APP_ENV=development
SECRET_KEY=your-256-bit-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
USE_REAL_LLAMA=false

# ---------- PostgreSQL ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finsight
POSTGRES_USER=finsight_user
POSTGRES_PASSWORD=your-postgres-password

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------- Qdrant ----------
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ---------- MinIO ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=finsight-documents

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-your-key-here

# ---------- LangSmith (development only) ----------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_PROJECT=finsight-ai

# ---------- Email (forgot password) ----------
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@finsight.ai
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# ---------- AWS (deployment only) ----------
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=me-south-1